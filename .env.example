# --- Server ---
PORT=5002
NODE_ENV=development
CORS_ORIGIN=*

# --- PostgreSQL (Railway) ---
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@reseau.proxy.rlwy.net:PORT/railway
DB_SSL=true

# --- Firebase Admin ---
GOOGLE_APPLICATION_CREDENTIALS=./bebeio-firebase-adminsdk-fbsvc-43dfd12570.json

# --- AI ---
AI_PROVIDER=groq
GROQ_API_KEY=

# --- Website (Paddle checkout page — must match Paddle default payment link) ---
WEB_CHECKOUT_URL=http://localhost:5173

# --- Paddle (website subscriptions — same Paddle account as your other app) ---
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=
# Create recurring prices in Paddle for Bebio Plus:
PADDLE_PRICE_ID_MONTHLY=
PADDLE_PRICE_ID_YEARLY=
# DISABLE_PADDLE_WEBHOOK_VERIFICATION=true
