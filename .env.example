# --- Server ---
PORT=5002
NODE_ENV=development
CORS_ORIGIN=*

# --- PostgreSQL (Railway) ---
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@reseau.proxy.rlwy.net:PORT/railway
DB_SSL=true

# --- Firebase Admin (local: JSON file; Railway: use env vars below) ---
GOOGLE_APPLICATION_CREDENTIALS=./bebeio-firebase-adminsdk-fbsvc-43dfd12570.json
# Railway — run: npm run extract:firebase ./bebeio-firebase-adminsdk-*.json
# FIREBASE_PROJECT_ID=bebeio
# FIREBASE_PRIVATE_KEY_ID=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@bebeio.iam.gserviceaccount.com

# --- AI ---
AI_PROVIDER=groq
GROQ_API_KEY=

# --- Website (Paddle checkout page — must match Paddle default payment link) ---
# Production: https://bebeio-web-production.up.railway.app
# Optional if Paddle default payment link already points to /upgrade on that domain.
WEB_CHECKOUT_URL=http://localhost:5173

# --- Paddle (website subscriptions — same Paddle account as your other app) ---
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=
# Create recurring prices in Paddle for Bebio Plus:
PADDLE_PRICE_ID_MONTHLY=
PADDLE_PRICE_ID_YEARLY=
# DISABLE_PADDLE_WEBHOOK_VERIFICATION=true
